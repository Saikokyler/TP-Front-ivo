---
import Layout from '../../layouts/Layout.astro';
import { albums } from '../../data/albums.js';

export async function getStaticPaths() {
  return albums.map((album) => ({
    params: { id: album.id.toString() },
    props: { album },
  }));
}

const { album } = Astro.props;
const LASTFM_KEY = 'aa091ec84d11e991188fc1e51a33e9ca';
const relatedAlbums = albums.filter((entry) => entry.artist === album.artist && entry.id !== album.id).slice(0, 3);
---

<Layout title={`${album.title} - ${album.artist}`}>
  <main class="album-page">
    <div class="container">
      <a href="/" class="back-link">&larr; Volver</a>

      <section class="album-main">
        <div class="album-cover">
          <img
            id="album-image"
            class="album-image"
            src="/placeholder.svg"
            alt={album.title}
            data-artist={album.artist}
            data-album={album.title}
          />
        </div>

        <div class="album-content">
          <p class="album-kicker">{album.genre} - {album.year}</p>
          <h1>{album.title}</h1>
          <p class="album-artist">{album.artist}</p>
          <p class="album-description">{album.description}</p>

          <div class="album-meta">
            <div><span>Sello</span><strong>{album.label}</strong></div>
            <div><span>Catalogo</span><strong>{album.catalogNumber}</strong></div>
            <div><span>Publicado</span><strong>{album.year}</strong></div>
            <div><span>Grabado</span><strong>{album.recorded}</strong></div>
            <div><span>Temas</span><strong>{album.tracks}</strong></div>
            <div><span>Rating</span><strong>{album.rating}/5</strong></div>
          </div>
        </div>
      </section>

      {album.trivia?.length > 0 && (
        <section class="section-block">
          <div class="section-head">
            <h2>Trivia</h2>
            <span id="trivia-score">0 / {album.trivia.length} correctas</span>
          </div>

          <div class="trivia-list">
            {album.trivia.map((question, questionIndex) => (
              <article class="trivia-item" data-question-index={questionIndex}>
                <p class="trivia-number">Pregunta {questionIndex + 1}</p>
                <p class="trivia-question">{question.pregunta}</p>
                <div class="trivia-options">
                  {question.opciones.map((option, optionIndex) => (
                    <button
                      class="trivia-option"
                      data-index={optionIndex}
                      data-correct={option.esCorrecta}
                    >
                      {option.texto}
                    </button>
                  ))}
                </div>
                <p class="trivia-feedback hidden"></p>
              </article>
            ))}
          </div>

          <div class="trivia-result hidden" id="trivia-result">
            <p id="trivia-message"></p>
          </div>
        </section>
      )}

      {relatedAlbums.length > 0 && (
        <section class="section-block">
          <div class="section-head">
            <h2>Mas de {album.artist}</h2>
          </div>
          <div class="related-grid">
            {relatedAlbums.map((relatedAlbum) => (
              <a href={`/album/${relatedAlbum.id}`} class="related-card">
                <img
                  src="/placeholder.svg"
                  alt={relatedAlbum.title}
                  data-artist={relatedAlbum.artist}
                  data-album={relatedAlbum.title}
                />
                <div>
                  <strong>{relatedAlbum.title}</strong>
                  <span>{relatedAlbum.year}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>
</Layout>

<script define:vars={{ LASTFM_KEY, albums }}>
  async function fetchAlbumImage(artist, searchTitle) {
    const titles = [searchTitle];

    if (searchTitle.toLowerCase().includes('in') && searchTitle.toLowerCase().includes('out')) {
      titles.push('In And Out', 'In n Out', "In 'n' Out");
    }

    for (const title of titles) {
      try {
        const url = `https://ws.audioscrobbler.com/2.0/?method=album.getinfo&api_key=${LASTFM_KEY}&artist=${encodeURIComponent(artist)}&album=${encodeURIComponent(title)}&format=json`;
        const res = await fetch(url);
        const data = await res.json();
        const images = data?.album?.image;

        if (images && images.length > 0) {
          const src = images[images.length - 1]['#text'];
          if (src) return src;
        }
      } catch (_) {}
    }

    return null;
  }

  async function loadCover() {
    const img = document.getElementById('album-image');
    if (!img) return;

    const artist = img.dataset.artist;
    const titleFromData = img.dataset.album;
    const albumData = albums.find((entry) => entry.title === titleFromData && entry.artist === artist);
    const searchTitle = albumData?.lastfmTitle || titleFromData;
    const src = await fetchAlbumImage(artist, searchTitle);

    if (src) {
      img.src = src;
      img.classList.add('loaded');
    }
  }

  function loadRelatedCovers() {
    document.querySelectorAll('.related-card img').forEach(async (img) => {
      const artist = img.dataset.artist;
      const titleFromData = img.dataset.album;
      const albumData = albums.find((entry) => entry.title === titleFromData && entry.artist === artist);
      const searchTitle = albumData?.lastfmTitle || titleFromData;
      const src = await fetchAlbumImage(artist, searchTitle);

      if (src) {
        img.src = src;
        img.classList.add('loaded');
      }
    });
  }

  function initTrivia() {
    const triviaItems = document.querySelectorAll('.trivia-item');
    const triviaScore = document.getElementById('trivia-score');
    const triviaResult = document.getElementById('trivia-result');
    const triviaMessage = document.getElementById('trivia-message');

    if (!triviaItems.length || !triviaScore || !triviaResult || !triviaMessage) return;

    let answered = 0;
    let correct = 0;
    const total = triviaItems.length;

    function updateScore() {
      triviaScore.textContent = `${correct} / ${total} correctas`;
    }

    triviaItems.forEach((item) => {
      const buttons = item.querySelectorAll('.trivia-option');
      const feedback = item.querySelector('.trivia-feedback');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          if (item.dataset.done === 'true') return;

          item.dataset.done = 'true';
          answered += 1;

          const isCorrect = button.dataset.correct === 'true';
          const correctButton = Array.from(buttons).find((entry) => entry.dataset.correct === 'true');

          buttons.forEach((entry) => {
            entry.disabled = true;
            if (entry.dataset.correct === 'true') entry.classList.add('ok');
          });

          if (isCorrect) {
            correct += 1;
            button.classList.add('ok');
            feedback.textContent = 'Correcta.';
          } else {
            button.classList.add('bad');
            feedback.innerHTML = `Incorrecta. La correcta es <strong>${correctButton?.textContent ?? ''}</strong>.`;
          }

          feedback.classList.remove('hidden');
          updateScore();

          if (answered === total) {
            triviaMessage.textContent = `Terminaste la trivia con ${correct} de ${total} respuestas correctas.`;
            triviaResult.classList.remove('hidden');
          }
        });
      });
    });

    updateScore();
  }

  loadCover();
  loadRelatedCovers();
  initTrivia();
</script>

<style>
  .album-page {
    padding: 2.5rem 0 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--blue-light);
    font-size: 0.95rem;
  }

  .album-main {
    display: grid;
    grid-template-columns: minmax(260px, 360px) 1fr;
    gap: 2rem;
    align-items: start;
  }

  .album-cover {
    background: var(--bg-card);
    border: 1px solid var(--border);
  }

  .album-image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .album-image.loaded,
  .related-card img.loaded {
    opacity: 1;
  }

  .album-kicker {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--blue-light);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .album-content h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.05;
    margin-bottom: 0.25rem;
  }

  .album-artist {
    color: var(--text-sub);
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }

  .album-description {
    color: var(--text-sub);
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .album-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0.75rem;
  }

  .album-meta div,
  .section-block,
  .related-card {
    border: 1px solid var(--border);
    background: var(--bg-card);
  }

  .album-meta div {
    padding: 0.85rem;
  }

  .album-meta span {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 0.35rem;
    font-family: var(--mono);
  }

  .album-meta strong {
    font-size: 0.95rem;
    color: var(--text);
  }

  .section-block {
    margin-top: 2rem;
    padding: 1.25rem;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .section-head h2 {
    font-size: 1.1rem;
  }

  .section-head span {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--mono);
  }

  .trivia-list {
    display: grid;
    gap: 0.9rem;
  }

  .trivia-item {
    padding: 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
  }

  .trivia-number {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-family: var(--mono);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .trivia-question {
    margin-bottom: 0.75rem;
  }

  .trivia-options {
    display: grid;
    gap: 0.6rem;
  }

  .trivia-option {
    text-align: left;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text);
    cursor: pointer;
  }

  .trivia-option:hover:not(:disabled) {
    border-color: var(--blue-light);
  }

  .trivia-option:disabled {
    cursor: default;
    opacity: 0.8;
  }

  .trivia-option.ok {
    border-color: #4caf50;
    background: rgba(76, 175, 80, 0.08);
  }

  .trivia-option.bad {
    border-color: #f44336;
    background: rgba(244, 67, 54, 0.08);
  }

  .trivia-feedback {
    margin-top: 0.7rem;
    color: var(--text-sub);
    font-size: 0.92rem;
  }

  .trivia-result {
    margin-top: 1rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    color: var(--text-sub);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 1rem;
  }

  .related-card {
    display: block;
    overflow: hidden;
  }

  .related-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background: var(--bg);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .related-card div {
    padding: 0.85rem;
  }

  .related-card strong {
    display: block;
    margin-bottom: 0.2rem;
    color: var(--text);
  }

  .related-card span {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 860px) {
    .album-main {
      grid-template-columns: 1fr;
    }

    .section-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
