---
import Layout from '../layouts/Layout.astro';
import AlbumCard from '../components/AlbumCard.astro';
import { albums, genres, artists } from '../data/albums.js';

const LASTFM_KEY = 'aa091ec84d11e991188fc1e51a33e9ca';
---

<Layout>
  <main class="page">
    <section class="intro">
      <div class="container intro__inner">
        <p class="intro__eyebrow">Blue Note catalog</p>
        <h1 class="intro__title">Un catalogo simple de jazz para recorrer 30 albumes esenciales.</h1>
        <p class="intro__text">
          Portadas, datos breves y una trivia corta por album.
        </p>
        <div class="intro__stats">
          <span>{albums.length} albumes</span>
          <span>{genres.length} generos</span>
          <span>{artists.length} artistas</span>
        </div>
      </div>
    </section>

    <section class="catalog" id="catalogo">
      <div class="container">
        <div class="toolbar">
          <input
            id="search"
            class="toolbar__search"
            type="text"
            placeholder="Buscar album o artista..."
            autocomplete="off"
          />
          <select id="filter-genre" class="toolbar__select">
            <option value="">Genero</option>
            <option>Hard Bop</option>
            <option>Soul Jazz</option>
            <option>Post-Bop</option>
            <option>Avant-Garde</option>
          </select>
          <select id="filter-decade" class="toolbar__select">
            <option value="">Epoca</option>
            <option>1950s</option>
            <option>1960s</option>
            <option>1970s</option>
          </select>
          <span class="toolbar__count"><span id="count">{albums.length}</span> resultados</span>
        </div>

        <div class="grid" id="album-grid">
          {albums.map((album) => <AlbumCard album={album} />)}
        </div>

        <p class="no-results hidden" id="empty-msg">Sin resultados.</p>
      </div>
    </section>
  </main>
</Layout>

<script define:vars={{ albums, LASTFM_KEY }}>
  async function loadCover(card) {
    const artist = card.dataset.artist;
    const album = card.dataset.album;
    const albumData = albums.find((entry) => entry.title === album && entry.artist === artist);
    const searchTitle = albumData?.lastfmTitle || album;

    try {
      const url = `https://ws.audioscrobbler.com/2.0/?method=album.getinfo&api_key=${LASTFM_KEY}&artist=${encodeURIComponent(artist)}&album=${encodeURIComponent(searchTitle)}&format=json`;
      const res = await fetch(url);
      const data = await res.json();
      const images = data?.album?.image;

      if (images) {
        const src = images[images.length - 1]['#text'];
        if (src) {
          const img = card.querySelector('.card__img');
          img.src = src;
          img.onload = () => img.classList.add('loaded');
        }
      }
    } catch (_) {}
  }

  function loadAllCovers() {
    document.querySelectorAll('.card[data-artist]').forEach(loadCover);
  }

  function filter() {
    const q = document.getElementById('search').value.toLowerCase();
    const genre = document.getElementById('filter-genre').value;
    const decade = document.getElementById('filter-decade').value;
    let count = 0;

    document.querySelectorAll('.card').forEach((card) => {
      const title = card.querySelector('.card__title').textContent.toLowerCase();
      const artist = card.querySelector('.card__artist').textContent.toLowerCase();
      const visible =
        (title.includes(q) || artist.includes(q)) &&
        (!genre || card.dataset.genre === genre) &&
        (!decade || card.dataset.decade === decade);

      card.style.display = visible ? '' : 'none';
      if (visible) count += 1;
    });

    document.getElementById('count').textContent = count;
    document.getElementById('empty-msg').classList.toggle('hidden', count > 0);
  }

  document.getElementById('search').addEventListener('input', filter);
  document.getElementById('filter-genre').addEventListener('change', filter);
  document.getElementById('filter-decade').addEventListener('change', filter);

  loadAllCovers();
</script>

<style>
  .page {
    padding: 3rem 0 4rem;
  }

  .intro {
    padding: 1rem 0 2.5rem;
  }

  .intro__inner {
    max-width: 820px;
  }

  .intro__eyebrow {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--blue-light);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .intro__title {
    font-size: clamp(2.1rem, 5vw, 4rem);
    line-height: 1.05;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .intro__text {
    max-width: 640px;
    color: var(--text-sub);
    font-size: 1rem;
  }

  .intro__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .intro__stats span {
    border: 1px solid var(--border);
    background: var(--bg-card);
    padding: 0.45rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-sub);
  }

  .catalog {
    padding-top: 1rem;
  }

  .toolbar {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) repeat(2, minmax(140px, 180px)) auto;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .toolbar__search,
  .toolbar__select {
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.8rem 0.95rem;
    font-size: 0.95rem;
    font-family: var(--font);
  }

  .toolbar__search:focus,
  .toolbar__select:focus {
    outline: none;
    border-color: var(--blue-light);
  }

  .toolbar__count {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 1rem;
  }

  .no-results {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
    font-family: var(--mono);
  }

  @media (max-width: 780px) {
    .page {
      padding-top: 2rem;
    }

    .toolbar {
      grid-template-columns: 1fr;
    }

    .toolbar__count {
      justify-self: start;
    }

    .grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }
</style>
