---
const { album } = Astro.props;
const searchQuery = `${album.title} ${album.artist}`;
---

<article
  class="card"
  data-genre={album.genre}
  data-decade={album.decade}
  data-search={searchQuery}
>
  <div class="card__img-wrap">
    <img
      class="card__cover"
      src="/placeholder.svg"
      alt={`${album.title} — ${album.artist}`}
      loading="lazy"
    />
    <div class="card__badge">{album.year}</div>
  </div>
  <div class="card__body">
    <p class="card__genre">{album.genre}</p>
    <h3 class="card__title">{album.title}</h3>
    <p class="card__artist">{album.artist}</p>
    <p class="card__desc">{album.description}</p>
    <p class="card__catalog">{album.catalogNumber}</p>
  </div>
</article>

<style>
  .card {
    background: var(--bg-dark);
    display: flex;
    flex-direction: column;
    transition: background var(--transition);
    cursor: default;
  }
  .card:hover { background: var(--bg-card); }

  .card__img-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #111;
  }
  .card__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .card__cover.loaded { opacity: 1; }
  .card:hover .card__cover { transform: scale(1.04); }

  .card__badge {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: rgba(0,0,0,0.75);
    color: var(--blue-note-light);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    letter-spacing: 0.08em;
    backdrop-filter: blur(4px);
  }

  .card__body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }
  .card__genre {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--blue-note-light);
    font-weight: 600;
  }
  .card__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
  }
  .card__artist {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }
  .card__desc {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-top: 0.25rem;
  }
  .card__catalog {
    font-size: 0.65rem;
    color: #333;
    letter-spacing: 0.08em;
    margin-top: auto;
    padding-top: 0.75rem;
  }
</style>