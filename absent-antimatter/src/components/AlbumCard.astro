---
const { album } = Astro.props;
---

<article
  class="card"
  data-genre={album.genre}
  data-decade={album.decade}
  data-artist={album.artist}
  data-album={album.title}
>
  <div class="card__img-wrap">
    <img class="card__img" src="/placeholder.svg" alt={album.title} loading="lazy" />
    <div class="card__year">{album.year}</div>
  </div>
  <div class="card__body">
    <span class="card__genre">{album.genre}</span>
    <h3 class="card__title">{album.title}</h3>
    <p class="card__artist">{album.artist}</p>
    <p class="card__desc">{album.description}</p>
    <span class="card__num">{album.catalogNumber}</span>
  </div>
</article>

<style>
.card {
  background: var(--bg);
  display: flex;
  flex-direction: column;
  transition: background var(--ease);
}
.card:hover { background: var(--bg-hover); }

.card__img-wrap {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: #0d0d0d;
}
.card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.5s ease, transform 0.4s ease;
}
.card__img.loaded { opacity: 1; }
.card:hover .card__img { transform: scale(1.04); }

.card__year {
  position: absolute;
  bottom: 0.6rem;
  right: 0.6rem;
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--blue-light);
  background: rgba(0,0,0,0.7);
  padding: 0.2rem 0.45rem;
  backdrop-filter: blur(4px);
  letter-spacing: 0.05em;
}

.card__body {
  padding: 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  flex: 1;
}
.card__genre {
  font-family: var(--mono);
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--blue-light);
}
.card__title {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
  letter-spacing: -0.01em;
}
.card__artist {
  font-size: 0.78rem;
  color: var(--text-sub);
  font-weight: 500;
}
.card__desc {
  font-size: 0.72rem;
  color: var(--text-muted);
  line-height: 1.55;
  margin-top: 0.3rem;
}
.card__num {
  font-family: var(--mono);
  font-size: 0.6rem;
  color: #222;
  margin-top: auto;
  padding-top: 0.6rem;
  letter-spacing: 0.08em;
}
</style> 